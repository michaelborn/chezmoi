{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "hyper": {
      "type": "remote",
      "url": "https://hyper.ortusbooks.com/~gitbook/mcp",
      "enabled": true
    },
    "coldbox": {
      "type": "remote",
      "url": "https://coldbox.ortusbooks.com/~gitbook/mcp",
      "enabled": true
    },
    "boxlang": {
      "type": "remote",
      "url": "https://boxlang.ortusbooks.com/~gitbook/mcp",
      "enabled": false
    },
    "qb": {
      "type": "remote",
      "url": "https://qb.ortusbooks.com/~gitbook/mcp",
      "enabled": true
    },
    "elasticsearch": {
      "type": "local",
      "command": ["uvx", "elasticsearch-mcp-server"],
      "enabled": true,
      "environment": {
        "ELASTICSEARCH_HOSTS": "http://ais-elasticsearch.revagency.net:9200",
        "ELASTICSEARCH_API_KEY": "zgd-1OizRfGzUuUAfIJwkw",
        "DISABLE_HIGH_RISK_OPERATIONS": "true"
      }
    }
  }
}
